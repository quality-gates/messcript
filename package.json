{
  "name": "messcript",
  "version": "0.1.0",
  "description": "An idiomatic JavaScript and TypeScript mess detector.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "messcript": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc --build",
    "check": "tsc --noEmit",
    "mutation": "stryker run && node scripts/covered-msi.mjs coverage/mutation/mutation.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/cli.test.mjs test/metrics.test.mjs test/package-smoke.test.mjs"
  },
  "dependencies": {
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/tap-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^24.0.0"
  }
}
