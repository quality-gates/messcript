{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": [
    "src/**/*.ts"
  ],
  "disableTypeChecks": "src/**/*.ts",
  "testRunner": "tap",
  "buildCommand": "npm run build",
  "checkers": [
    "typescript"
  ],
  "tsconfigFile": "tsconfig.json",
  "tap": {
    "testFiles": [
      "test/cli.test.mjs",
      "test/metrics.test.mjs",
      "test/ast-metrics.test.mjs"
    ]
  },
  "coverageAnalysis": "perTest",
  "reporters": [
    "clear-text",
    "json"
  ],
  "jsonReporter": {
    "fileName": "coverage/mutation/mutation.json"
  },
  "cleanTempDir": "always",
  "tempDirName": "coverage/mutation/.stryker-tmp",
  "thresholds": {
    "break": null
  }
}
